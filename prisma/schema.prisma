// Prisma schema for ShareCircle

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
        
// Enums for Circle Management
enum MemberRole {
  ADMIN
  MEMBER
}

enum JoinType {
  CREATED
  CODE
  LINK
}

enum ConversationType {
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  SYSTEM
}

enum AttachmentType {
  IMAGE
  FILE
}

// Enums for Borrowing/Request Management
enum ItemRequestStatus {
  OPEN
  FULFILLED
  CANCELLED
}

enum BorrowRequestStatus {
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

enum BorrowQueueStatus {
  WAITING
  READY
  SKIPPED
  CANCELLED
}

enum BorrowTransactionStatus {
  ACTIVE
  RETURN_PENDING
  COMPLETED
  CANCELLED
}

enum NotificationType {
  // Item request notifications
  ITEM_REQUEST_CREATED
  ITEM_REQUEST_FULFILLED
  // Borrow request notifications
  BORROW_REQUEST_RECEIVED
  BORROW_REQUEST_APPROVED
  BORROW_REQUEST_DECLINED
  // Queue notifications
  QUEUE_POSITION_UPDATED
  QUEUE_ITEM_READY
  // Return notifications
  RETURN_REQUESTED
  RETURN_CONFIRMED
  // Message notifications
  NEW_MESSAGE
}

enum NotificationStatus {
  UNREAD
  READ
}

// User model with requested fields
model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime? @map("email_verified")
  image             String?
  hashed_password   String?
  phone_number      String?   @unique
  country_code      String?
  address           String?
  zip_code          String?
  country           String?
  profile_media_url String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Circle relations
  createdCircles    Circle[]       @relation("CircleCreator")
  circleMemberships CircleMember[]

  // Item relations
  items Item[]

  // Chat relations
  conversationsCreated    Conversation[]            @relation("ConversationCreator")
  conversationMemberships ConversationParticipant[]
  sentMessages            Message[]
  messageReceipts         MessageReceipt[]

  // Borrowing relations
  itemRequests            ItemRequest[]
  borrowRequestsAsRequester BorrowRequest[]         @relation("BorrowRequester")
  borrowRequestsAsOwner   BorrowRequest[]           @relation("BorrowOwner")
  borrowQueueEntries      BorrowQueue[]
  borrowTransactionsAsBorrower BorrowTransaction[]  @relation("Borrower")
  borrowTransactionsAsOwner BorrowTransaction[]     @relation("TransactionOwner")
  notifications           Notification[]

  @@map("users")
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Circle model for group management
model Circle {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  inviteCode  String   @unique @map("invite_code")
  inviteExpiresAt DateTime @default(dbgenerated("now() + interval '7 days'")) @map("invite_expires_at")
  avatarUrl   String?  @map("avatar_url")
  avatarPath  String?  @map("avatar_path")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  createdBy    User           @relation("CircleCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      CircleMember[]
  items        ItemCircle[]
  itemRequestCircles ItemRequestCircle[]

  @@index([createdById])
  @@map("circles")
}

// CircleMember model for membership tracking
model CircleMember {
  id       String     @id @default(cuid())
  circleId String     @map("circle_id")
  userId   String     @map("user_id")
  role     MemberRole @default(MEMBER)
  joinType JoinType   @map("join_type")
  joinedAt DateTime   @default(now()) @map("joined_at")
  leftAt   DateTime?  @map("left_at")

  // Relations
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([circleId, userId])
  @@index([circleId])
  @@index([userId])
  @@index([leftAt])
  @@map("circle_members")
}

// Item model for shared items
model Item {
  id           String   @id @default(cuid())
  ownerId      String   @map("owner_id")
  imagePath    String   @map("image_path")
  name         String
  description  String?  @db.Text
  categories   String[] @default([])
  tags         String[] @default([])
  mediaPaths   String[] @default([]) @map("media_paths")
  isAvailable  Boolean  @default(true) @map("is_available")
  // Vector embeddings stored via raw SQL (pgvector)
  embedding    Unsupported("vector(1024)")?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  owner              User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  circles            ItemCircle[]
  borrowRequests     BorrowRequest[]
  borrowQueue        BorrowQueue[]
  borrowTransactions BorrowTransaction[]

  @@index([ownerId])
  @@index([isAvailable])
  @@map("items")
}

// ItemCircle model for sharing items across multiple circles
model ItemCircle {
  id       String   @id @default(cuid())
  itemId   String   @map("item_id")
  circleId String   @map("circle_id")
  sharedAt DateTime @default(now()) @map("shared_at")

  // Relations
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  circle Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([itemId, circleId])
  @@index([circleId])
  @@index([itemId])
  @@map("item_circles")
}

model Conversation {
  id            String            @id @default(cuid())
  type          ConversationType  @default(DIRECT)
  createdById   String            @map("created_by")
  lastMessageAt DateTime?         @map("last_message_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  createdBy     User                      @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  participants  ConversationParticipant[]
  messages      Message[]

  @@index([createdById])
  @@map("conversations")
}

model ConversationParticipant {
  id             String    @id @default(cuid())
  conversationId String    @map("conversation_id")
  userId         String    @map("user_id")
  pinnedAt       DateTime? @map("pinned_at")
  archivedAt     DateTime? @map("archived_at")
  mutedUntil     DateTime? @map("muted_until")
  deletedAt      DateTime? @map("deleted_at")
  lastReadAt     DateTime? @map("last_read_at")
  joinedAt       DateTime  @default(now()) @map("joined_at")
  leftAt         DateTime? @map("left_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([deletedAt])
  @@map("conversation_participants")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String      @map("conversation_id")
  senderId       String      @map("sender_id")
  clientId       String?     @map("client_id")
  body           String      @db.Text
  messageType    MessageType @default(TEXT) @map("message_type")
  createdAt      DateTime    @default(now()) @map("created_at")
  editedAt       DateTime?   @map("edited_at")

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation(fields: [senderId], references: [id], onDelete: Cascade)
  receipts     MessageReceipt[]
  attachments  MessageAttachment[]

  @@index([conversationId, createdAt])
  @@unique([senderId, clientId])
  @@map("messages")
}

model MessageReceipt {
  id          String    @id @default(cuid())
  messageId   String    @map("message_id")
  userId      String    @map("user_id")
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_receipts")
}

model MessageAttachment {
  id        String         @id @default(cuid())
  messageId String         @map("message_id")
  type      AttachmentType @map("type")
  url       String         @map("url")
  metadata  Json?          @map("metadata")
  createdAt DateTime       @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("message_attachments")
}

// Item Request - when user can't find an item they need
model ItemRequest {
  id          String            @id @default(cuid())
  requesterId String            @map("requester_id")
  title       String
  description String?           @db.Text
  desiredFrom DateTime?         @map("desired_from")
  desiredTo   DateTime?         @map("desired_to")
  status      ItemRequestStatus @default(OPEN)
  fulfilledBy String?           @map("fulfilled_by") // itemId that fulfilled this request
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  requester User   @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  circles   ItemRequestCircle[]

  @@index([requesterId])
  @@index([status])
  @@map("item_requests")
}

// Join table for item requests shared to multiple circles
model ItemRequestCircle {
  id            String      @id @default(cuid())
  itemRequestId String      @map("item_request_id")
  circleId      String      @map("circle_id")
  sharedAt      DateTime    @default(now()) @map("shared_at")

  itemRequest ItemRequest @relation(fields: [itemRequestId], references: [id], onDelete: Cascade)
  circle      Circle      @relation(fields: [circleId], references: [id], onDelete: Cascade)

  @@unique([itemRequestId, circleId])
  @@index([circleId])
  @@index([itemRequestId])
  @@map("item_request_circles")
}

// Borrow Request - request to borrow a specific item
model BorrowRequest {
  id          String              @id @default(cuid())
  itemId      String              @map("item_id")
  requesterId String              @map("requester_id")
  ownerId     String              @map("owner_id")
  message     String?             @db.Text
  desiredFrom DateTime            @map("desired_from")
  desiredTo   DateTime            @map("desired_to")
  status      BorrowRequestStatus @default(PENDING)
  declineNote String?             @map("decline_note") @db.Text
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  item        Item               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  requester   User               @relation("BorrowRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  owner       User               @relation("BorrowOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  transaction BorrowTransaction?

  @@index([itemId])
  @@index([requesterId])
  @@index([ownerId])
  @@index([status])
  @@map("borrow_requests")
}

// Borrow Queue - queue for items that are currently unavailable
model BorrowQueue {
  id          String            @id @default(cuid())
  itemId      String            @map("item_id")
  requesterId String            @map("requester_id")
  position    Int
  message     String?           @db.Text
  desiredFrom DateTime?         @map("desired_from")
  desiredTo   DateTime?         @map("desired_to")
  status      BorrowQueueStatus @default(WAITING)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  item      Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  requester User @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([itemId, requesterId])
  @@index([itemId, position])
  @@index([requesterId])
  @@index([status])
  @@map("borrow_queue")
}

// Borrow Transaction - active borrow record
model BorrowTransaction {
  id              String                   @id @default(cuid())
  borrowRequestId String                   @unique @map("borrow_request_id")
  itemId          String                   @map("item_id")
  borrowerId      String                   @map("borrower_id")
  ownerId         String                   @map("owner_id")
  borrowedAt      DateTime                 @default(now()) @map("borrowed_at")
  dueAt           DateTime                 @map("due_at")
  returnedAt      DateTime?                @map("returned_at")
  status          BorrowTransactionStatus  @default(ACTIVE)
  returnNote      String?                  @map("return_note") @db.Text
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  borrowRequest BorrowRequest @relation(fields: [borrowRequestId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  borrower      User          @relation("Borrower", fields: [borrowerId], references: [id], onDelete: Cascade)
  owner         User          @relation("TransactionOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([borrowerId])
  @@index([ownerId])
  @@index([status])
  @@map("borrow_transactions")
}

// Notification model for alerts
model Notification {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  type      NotificationType
  entityId  String?            @map("entity_id") // ID of related entity (request, transaction, etc.)
  title     String
  body      String             @db.Text
  metadata  Json?              // Additional data for the notification
  status    NotificationStatus @default(UNREAD)
  createdAt DateTime           @default(now()) @map("created_at")
  readAt    DateTime?          @map("read_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
  @@map("notifications")
}
